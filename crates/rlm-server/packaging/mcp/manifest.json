  "install": {
    "windows_installer_url": "https://raw.githubusercontent.com/stevenke1981/rlm-mcp/main/packaging/windows/install.ps1",
    "linux_installer_url": "https://raw.githubusercontent.com/stevenke1981/rlm-mcp/main/packaging/linux/install.sh",
    "macos_installer_url": "https://raw.githubusercontent.com/stevenke1981/rlm-mcp/main/packaging/macos/install.sh",
    "stable_windows_binary": "%USERPROFILE%/.config/rlm-mcp/bin/rlm-mcp.exe",
    "stable_unix_binary": "~/.config/rlm-mcp/bin/rlm-mcp",
    "recommended_command": "./install.ps1",
    "manual_templates": [
      "packaging/mcp/generic-mcp.json",
      "packaging/mcp/codex-config.toml",
      "packaging/mcp/opencode.json",
      "packaging/mcp/claude-settings.json"
