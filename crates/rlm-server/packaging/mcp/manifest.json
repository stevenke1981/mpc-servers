    "rlm_repl_execute",
    "rlm_repl_info",
    "rlm_scan",
    "rlm_session_cleanup",
    "rlm_session_delete",
    "rlm_session_export",
    "rlm_session_import",
    "rlm_session_list",
    "rlm_slice",
    "rlm_task_cancel",
    "rlm_task_create",
    "rlm_task_list",
    "rlm_task_reduce",
    "rlm_task_result",
    "rlm_tools_reference",
